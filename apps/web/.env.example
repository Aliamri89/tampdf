# URL of the deployed worker service (apps/worker) that handles server-side
# document conversions (PDF <-> Word). Leave unset locally to disable those
# two tools gracefully; run `npm run dev:worker` and set this to
# http://localhost:8787 to enable them.
WORKER_URL=

# Shared secret sent as the x-api-key header to the worker. Must match
# WORKER_API_KEY in apps/worker's environment.
WORKER_API_KEY=
