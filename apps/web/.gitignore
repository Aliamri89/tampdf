# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# payload cms
*.db
*.db-journal
/media-uploads
# payload/payload-types.ts is intentionally committed (not ignored) — it's
# imported directly by app code, and Hostinger's build has no reliable way
# to run `payload generate:types` before `next build`. Regenerate it with
# `npm run generate:types -w web` and commit the result whenever a
# collection/global in apps/web/payload/ changes.
